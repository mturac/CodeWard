{
  "name": "codeward",
  "version": "0.1.0",
  "type": "module",
  "description": "Open-source repo guardrails for AI-assisted engineering.",
  "license": "Apache-2.0",
  "bin": {
    "codeward": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codeward/agents-md": "workspace:*",
    "@codeward/analyzer": "workspace:*",
    "@codeward/core": "workspace:*",
    "@codeward/github": "workspace:*",
    "@codeward/rules": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {}
}
