{
  "name": "codeward-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:web": "pnpm --filter @codeward/web build",
    "check": "node scripts/check.mjs",
    "codeward": "node apps/cli/dist/index.js",
    "dev:web": "pnpm --filter @codeward/web dev",
    "format": "node scripts/check-format.mjs",
    "lint": "node scripts/check-format.mjs",
    "preview:web": "pnpm --filter @codeward/web preview",
    "test": "node scripts/test.mjs",
    "typecheck": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
