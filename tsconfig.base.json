{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "@codeward/agents-md": ["packages/agents-md/src/index.ts"],
      "@codeward/analyzer": ["packages/analyzer/src/index.ts"],
      "@codeward/core": ["packages/core/src/index.ts"],
      "@codeward/github": ["packages/github/src/index.ts"],
      "@codeward/rules": ["packages/rules/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  }
}
